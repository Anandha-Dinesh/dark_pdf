{
  "manifest_version": 3,
  "name": "NoirPDF",
  "version": "0.1.0",
  "description": "NoirPDF helps you to view the pdfs with light theme to dark theme.",
  "permissions": ["tabs", "storage", "webRequest", "webNavigation"],
  "host_permissions": ["*://*/*.pdf", "file://*/*.pdf"],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/logo.png",
    "32": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  },
  "action": {
    "default_title": "NoirPDF",
    "default_icon": {
      "32": "assets/logo.png",
      "16": "assets/logo.png"
    }
  }
}
